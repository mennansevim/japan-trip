# === AI Sağlayıcı ===
# "ollama" (ücretsiz lokal · varsayılan) veya "cursor" (Cursor SDK · ücretli)
AI_PROVIDER=ollama

# Ollama ayarları (AI_PROVIDER=ollama ise)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Cursor SDK ayarları (AI_PROVIDER=cursor ise)
# CURSOR_API_KEY=cursor_...     # https://cursor.com/dashboard/cloud-agents
# CURSOR_REVIEW_MODEL=composer-2

# === Raspberry Pi Deploy Ayarları (opsiyonel) ===
# Bu değişkenler tanımlı değilse "Pi'ye deploy" adımı sessizce atlanır.
PI_HOST=192.168.1.60
PI_USER=mennano
PI_PASSWORD=__buraya_parola__
PI_REPO_DIR=agora-voice-chatbot-web
PI_BRANCH=main
PI_DEPLOY_CMD=git pull origin main && docker compose down && docker compose up -d --build

# Push edilecek branch (opsiyonel, varsayılan: PI_BRANCH veya mevcut branch)
# PUSH_BRANCH=main
